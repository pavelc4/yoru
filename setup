#!/usr/bin/env bash

# Setup strict error handling
set -e

# Terminal Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Print helper functions
info() { echo -e "${BLUE}${BOLD}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}${BOLD}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}${BOLD}[WARNING]${NC} $1"; }
error() { echo -e "${RED}${BOLD}[ERROR]${NC} $1"; exit 1; }

# Header Banner
show_banner() {
    echo -e "${MAGENTA}${BOLD}"
    echo "██╗   ██╗ ██████╗ ██████╗ ██╗   ██╗"
    echo "╚██╗ ██╔╝██╔═══██╗██╔══██╗██║   ██║"
    echo " ╚████╔╝ ██║   ██║██████╔╝██║   ██║"
    echo "  ╚██╔╝  ██║   ██║██╔══██╗██║   ██║"
    echo "   ██║   ╚██████╔╝██║  ██║╚██████╔╝"
    echo "   ╚═╝    ╚═════╝ ╚═╝  ╚═╝ ╚═════╝ "
    echo -e "${NC}"
}

# Global Help
show_help() {
    show_banner
    echo -e "${BOLD}Yoru Dotfiles Manager — Unified Desktop Setup Utility${NC}"
    echo -e "Author: ${CYAN}pavelc4${NC} | Stack: ${CYAN}Hyprland & Quickshell${NC}"
    echo "--------------------------------------------------------"
    echo -e "Usage: ${BOLD}./setup <subcommand>${NC}"
    echo ""
    echo "Subcommands:"
    echo -e "  ${GREEN}install${NC}         Install, compile QML C++ plugin, and link configurations."
    echo -e "  ${RED}uninstall${NC}       Safely revert configurations and restore your backups."
    echo -e "  ${YELLOW}help${NC}            Show this documentation."
    echo "--------------------------------------------------------"
}

# -----------------------------------------------------------------------------
# INSTALL Subcommand
# -----------------------------------------------------------------------------
run_install() {
    show_banner
    echo -e "${BOLD}Yoru Dotfiles Installer — Starting Local Desktop Setup...${NC}"
    echo "--------------------------------------------------------"
    
    # 1. Verify OS
    if [ ! -f /etc/arch-release ]; then
        warn "This script is optimized for Arch Linux. Proceed with caution."
    fi

    # Define paths
    local REPO_DIR
    REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local HYPR_SRC="$REPO_DIR/hypr"
    local QS_SRC="$REPO_DIR/quickshell/yoru"

    # 2. Check Dependencies
    info "Checking package dependencies..."
    local REQUIRED_BINARIES=(
        "hyprland"
        "quickshell"
        "grim"
        "slurp"
        "wl-copy"
        "hyprpicker"
        "tesseract"
        "curl"
        "jq"
        "wf-recorder"
        "app2unit"
    )

    local MISSING_BINS=()
    for bin in "${REQUIRED_BINARIES[@]}"; do
        if ! command -v "$bin" &> /dev/null; then
            MISSING_BINS+=("$bin")
        fi
    done

    # Check for libcava (AUR)
    local HAS_LIBCAVA=true
    if ! pkg-config --exists libcava &> /dev/null && ! pkg-config --exists cava &> /dev/null; then
        HAS_LIBCAVA=false
    fi

    if [ ${#MISSING_BINS[@]} -ne 0 ] || [ "$HAS_LIBCAVA" = false ]; then
        warn "Some required dependencies or libraries are missing."
        if [ ${#MISSING_BINS[@]} -ne 0 ]; then
            echo -e "  Missing binaries: ${RED}${MISSING_BINS[*]}${NC}"
        fi
        if [ "$HAS_LIBCAVA" = false ]; then
            echo -e "  Missing library: ${RED}libcava${NC} (Required for audio visualizer)"
        fi
        
        echo ""
        read -rp "Would you like to install missing dependencies using yay? [Y/n] " install_deps
        if [[ "$install_deps" =~ ^[YyDd]$ ]] || [ -z "$install_deps" ]; then
            info "Installing dependencies..."
            local INSTALL_LIST=()
            for bin in "${MISSING_BINS[@]}"; do
                case "$bin" in
                    "hyprland") INSTALL_LIST+=("hyprland") ;;
                    "quickshell") INSTALL_LIST+=("quickshell-git") ;;
                    "grim") INSTALL_LIST+=("grim") ;;
                    "slurp") INSTALL_LIST+=("slurp") ;;
                    "wl-copy") INSTALL_LIST+=("wl-clipboard") ;;
                    "hyprpicker") INSTALL_LIST+=("hyprpicker") ;;
                    "tesseract") INSTALL_LIST+=("tesseract" "tesseract-data-eng") ;;
                    "curl") INSTALL_LIST+=("curl") ;;
                    "jq") INSTALL_LIST+=("jq") ;;
                    "wf-recorder") INSTALL_LIST+=("wf-recorder") ;;
                    "app2unit") INSTALL_LIST+=("app2unit") ;;
                esac
            done
            
            if [ "$HAS_LIBCAVA" = false ]; then
                INSTALL_LIST+=("libcava")
            fi
            
            if command -v yay &> /dev/null; then
                yay -S --needed "${INSTALL_LIST[@]}"
            elif command -v paru &> /dev/null; then
                paru -S --needed "${INSTALL_LIST[@]}"
            else
                error "No AUR helper (yay/paru) found. Please install: ${INSTALL_LIST[*]} manually."
            fi
        else
            warn "Proceeding without installing missing packages. Builds might fail."
        fi
    else
        success "All core dependencies and libraries are present!"
    fi

    # 3. Build QML C++ Plugin
    info "Building and compiling Quickshell QML plugin..."
    if [ -d "$QS_SRC" ]; then
        cd "$QS_SRC"
        mkdir -p build
        cd build
        info "Configuring CMake..."
        cmake -DCMAKE_INSTALL_PREFIX=../imports -DINSTALL_QMLDIR=. -DVERSION=0.1.0 -DGIT_REVISION=dev ..
        info "Compiling plugin..."
        make -j$(nproc)
        info "Installing plugin locally..."
        make install
        success "C++ QML Plugin compiled and installed locally to imports/ successfully!"
    else
        error "Quickshell configuration path not found in repository: $QS_SRC"
    fi

    # 4. Backup & Symlink Configurations
    info "Setting up symlinks in ~/.config..."
    mkdir -p "$HOME/.config"

    link_config() {
        local src="$1"
        local dest="$2"
        local name="$3"
        
        if [ -e "$dest" ] || [ -L "$dest" ]; then
            if [ -L "$dest" ] && [ "$(readlink -f "$dest")" = "$(readlink -f "$src")" ]; then
                success "$name is already correctly symlinked."
                return
            fi
            
            local backup="${dest}.bak.$(date +%Y%m%d_%H%M%S)"
            warn "Existing $name config found! Moving to $backup"
            mv "$dest" "$backup"
        fi
        
        mkdir -p "$(dirname "$dest")"
        ln -s "$src" "$dest"
        success "Symlinked $name to $dest"
    }

    # Link Configurations
    cd "$REPO_DIR"
    link_config "$HYPR_SRC" "$HOME/.config/hypr" "Hyprland Lua"
    link_config "$QS_SRC" "$HOME/.config/quickshell/yoru" "Quickshell Yoru"
    if [ -d "$REPO_DIR/kitty" ]; then
        link_config "$REPO_DIR/kitty" "$HOME/.config/kitty" "Kitty Terminal"
    fi
    if [ -d "$REPO_DIR/foot" ]; then
        link_config "$REPO_DIR/foot" "$HOME/.config/foot" "Foot Terminal"
    fi

    # Kill old quickshell instances to prevent duplicates
    info "Terminating any old quickshell instances..."
    pkill quickshell || true
    pkill qs || true

    # Reload active Hyprland configuration
    if command -v hyprctl &> /dev/null && hyprctl activewindow &> /dev/null; then
        info "Hyprland session detected! Reloading configuration..."
        hyprctl reload
        
        echo ""
        read -rp "Would you like to exit your current Hyprland session to load Yoru completely fresh? [y/N] " exit_choice
        if [[ "$exit_choice" =~ ^[Yy]$ ]]; then
            info "Exiting Hyprland..."
            pkill Hyprland || killall Hyprland
        fi

    fi

    echo "--------------------------------------------------------"
    success "Yoru Dotfiles installation completed successfully!"
    info "You can now test running quickshell using (works in any shell):"
    echo -e "  ${BOLD}env QML2_IMPORT_PATH=\$HOME/.config/quickshell/yoru/imports quickshell -p \$HOME/.config/quickshell/yoru/shell.qml${NC}"
    info "Or refresh Hyprland manually: ${BOLD}hyprctl reload${NC}"
    echo "--------------------------------------------------------"

}

# -----------------------------------------------------------------------------
# UNINSTALL Subcommand
# -----------------------------------------------------------------------------
run_uninstall() {
    show_banner
    echo -e "${BOLD}Yoru Dotfiles Uninstaller — Reverting Configuration Setup...${NC}"
    echo "--------------------------------------------------------"
    
    local REPO_DIR
    REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local CONFIG_DIR="$HOME/.config"

    # Helper function to find the latest backup folder
    find_latest_backup() {
        local target="$1"
        local backups=($(ls -td "${target}.bak."* 2>/dev/null || true))
        if [ ${#backups[@]} -gt 0 ]; then
            echo "${backups[0]}"
        else
            echo ""
        fi
    }

    # Helper to unlink and restore
    unlink_and_restore() {
        local dest="$2"
        local name="$1"
        
        if [ -L "$dest" ]; then
            local target_path
            target_path="$(readlink -f "$dest" || true)"
            if [[ "$target_path" == "$REPO_DIR"* ]]; then
                info "Removing $name symlink: $dest"
                rm "$dest"
                success "Removed $name symlink successfully."
                
                local latest_backup
                latest_backup=$(find_latest_backup "$dest")
                if [ -n "$latest_backup" ] && [ -d "$latest_backup" ]; then
                    echo -e "${CYAN}➜ Found backup:${NC} $(basename "$latest_backup")"
                    read -rp "Would you like to restore this backup? [Y/n] " restore_choice
                    if [[ "$restore_choice" =~ ^[YyDd]$ ]] || [ -z "$restore_choice" ]; then
                        mv "$latest_backup" "$dest"
                        success "Restored backup to $dest successfully!"
                    else
                        info "Skipped backup restoration for $name."
                    fi
                fi
            else
                warn "$dest is a symlink but does not point to the Yoru repo. Skipping."
            fi
        elif [ -e "$dest" ]; then
            warn "$dest exists but is a physical folder. Skipping to prevent data loss."
        else
            info "$name config ($dest) is not currently symlinked. Skipping."
        fi
        echo ""
    }

    # Revert symlinks
    unlink_and_restore "Hyprland Lua" "$CONFIG_DIR/hypr"
    unlink_and_restore "Quickshell Yoru" "$CONFIG_DIR/quickshell/yoru"
    unlink_and_restore "Kitty Terminal" "$CONFIG_DIR/kitty"
    unlink_and_restore "Foot Terminal" "$CONFIG_DIR/foot"

    # Clean build caches
    info "Checking compiled build files..."
    local BUILD_DIR="$REPO_DIR/quickshell/yoru/build"
    local IMPORTS_DIR="$REPO_DIR/quickshell/yoru/imports"

    if [ -d "$BUILD_DIR" ] || [ -d "$IMPORTS_DIR" ]; then
        read -rp "Would you like to completely delete local compiled build and imports cache folders? [y/N] " clean_choice
        if [[ "$clean_choice" =~ ^[Yy]$ ]]; then
            info "Cleaning build files..."
            rm -rf "$BUILD_DIR" "$IMPORTS_DIR"
            success "Local build and imports directories deleted cleanly."
        else
            info "Retained build caches."
        fi
    fi

    echo "--------------------------------------------------------"
    success "Yoru Dotfiles configurations reverted cleanly!"
    info "Thank you for using Yoru!"
    echo "--------------------------------------------------------"
}

# -----------------------------------------------------------------------------
# Main Subcommand Router
# -----------------------------------------------------------------------------
case "$1" in
    "install")
        run_install
        ;;
    "uninstall")
        run_uninstall
        ;;
    "help"|"--help"|-h|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown subcommand: \"$1\"${NC}"
        show_help
        exit 1
        ;;
esac
